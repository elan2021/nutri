# Provedor de IA: "gemini" (padrão) ou "anthropic"
AI_PROVIDER=gemini

# Gemini — obrigatório se AI_PROVIDER=gemini
GEMINI_API_KEY=sua-chave-aqui

# Modelo Gemini (padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Anthropic — obrigatório se AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
